<div class="headapicomponent-container">
    <h2>
        Демонстрация работы HeadAPI
    </h2>
    <div>Element PS as JML: {{ elementPS }} </div>
    <div>Element найденный в DOM: {{ foundItem }} </div>
    <Controls.buttons:Button caption="Set red color via HeadAPI" on:click="_createScript()"/>
    <div id="headapi_colorbox" class="headapicomponent_targetbox" style="background-color: blue; margin: 50px; padding: 10px; border: 5px solid black; width: 25px; height: 25px">
    </div>
</div>
